<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.hebei.systemdemo.mapper.SysUserMapper">

    <resultMap id="SysUserResultMap" type="com.hebei.systemdemo.domain.po.SysUser">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="realName" column="real_name"/>
        <result property="passwordHash" column="password_hash"/>
        <result property="phone" column="phone"/>
        <result property="status" column="status"/>
        <result property="isDeleted" column="is_deleted"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="getByUsername" parameterType="java.lang.String" resultMap="SysUserResultMap">
        SELECT
            id,
            username,
            real_name,
            password_hash,
            phone,
            status,
            is_deleted,
            created_at,
            updated_at
        FROM sys_user
        WHERE username = #{username}
          AND is_deleted = 0
    </select>

    <select id="getById" parameterType="java.lang.Long" resultMap="SysUserResultMap">
        SELECT
            id,
            username,
            real_name,
            password_hash,
            phone,
            status,
            is_deleted,
            created_at,
            updated_at
        FROM sys_user
        WHERE id = #{id}
          AND is_deleted = 0
    </select>

    <insert id="insert" parameterType="com.hebei.systemdemo.domain.po.SysUser" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_user
        <trim prefix="(" suffix=")" suffixOverrides=",">
            username,
            real_name,
            password_hash,
            <if test="phone != null and phone != ''">phone,</if>
            <if test="status != null">status,</if>
            <if test="isDeleted != null">is_deleted,</if>
            <if test="createdAt != null">created_at,</if>
            <if test="updatedAt != null">updated_at,</if>
        </trim>

        <trim prefix="VALUES (" suffix=")" suffixOverrides=",">
            #{username},
            #{realName},
            #{passwordHash},
            <if test="phone != null and phone != ''">#{phone},</if>
            <if test="status != null">#{status},</if>
            <if test="isDeleted != null">#{isDeleted},</if>
            <if test="createdAt != null">#{createdAt},</if>
            <if test="updatedAt != null">#{updatedAt},</if>
        </trim>
    </insert>

    <update id="updateById" parameterType="com.hebei.systemdemo.domain.po.SysUser">
        UPDATE sys_user
        <set>
            <if test="username != null and username != ''">username = #{username},</if>
            <if test="realName != null and realName != ''">real_name = #{realName},</if>
            <if test="passwordHash != null and passwordHash != ''">password_hash = #{passwordHash},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="status != null">status = #{status},</if>
            <if test="isDeleted != null">is_deleted = #{isDeleted},</if>
            <if test="updatedAt != null">updated_at = #{updatedAt},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById" parameterType="java.lang.Long">
        UPDATE sys_user SET is_deleted = 1 WHERE id = #{id}
    </delete>

</mapper>
